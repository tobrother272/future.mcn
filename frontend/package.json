    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.10.4",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
