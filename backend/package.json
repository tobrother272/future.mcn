{
  "name": "meridian-backend",
  "version": "1.0.0",
  "description": "Meridian MCN — PostgreSQL REST API",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "start:v6": "node --import tsx/esm src/server.ts",
    "dev:v6": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "node --loader ts-node/esm src/db/migrate-from-blob.ts",
    "migrate:up": "node-pg-migrate up -d $DATABASE_URL --migrations-dir migrations",
    "seed": "psql $DATABASE_URL -f seeds/cms-kudo.sql -f seeds/topics-kudo.sql"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "jose": "^5.10.0",
    "kysely": "^0.29.0",
    "multer": "^2.1.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.11.5",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.40",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0"
  }
}
