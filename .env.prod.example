# ─────────────────────────────────────────────────────────────────────────────
# Meridian MCN — production env file template
#
#   1.  cp .env.prod.example .env.prod
#   2.  Đổi TẤT CẢ các giá trị có dấu "CHANGE_ME"
#   3.  chmod 600 .env.prod   (chỉ owner đọc được)
#   4.  KHÔNG commit file .env.prod vào git
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain + Port ───────────────────────────────────────────────────────────
# Domain công khai (qua DDNS MikroTik). Cần đã NAT port FRONTEND_HOST_PORT
# (mặc định 8080) từ WAN router về VPS.
PUBLIC_DOMAIN=hfa0966545s.sn.mynetname.net

# Port HTTP public — 80/443 trên NAT này đã bị thiết bị khác chiếm, nên
# Meridian publish trên port 8080. Nếu sau này giải phóng 80/443 có thể
# đổi về 80 và bổ sung Caddy auto-HTTPS.
FRONTEND_HOST_PORT=8080

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=meridian
POSTGRES_USER=meridian
# Mật khẩu DB — đặt ít nhất 24 ký tự, mix chữ HOA/thường/số/ký tự đặc biệt.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── Backend ─────────────────────────────────────────────────────────────────
# Khóa ký JWT — TỐI THIỂU 32 ký tự ngẫu nhiên. Sinh bằng:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS_xxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d

# Whitelist Origin cho CORS. Vì FE và BE cùng origin (FE proxy /api/* sang BE
# qua nginx nội bộ) nên thực tế CORS không kích hoạt, nhưng vẫn nên set đúng:
CORS_ORIGINS=http://hfa0966545s.sn.mynetname.net:8080

# Mức log: info (mặc định) | warn | error  — production khuyến nghị info hoặc warn.
LOG_LEVEL=info

# Token legacy cho Partner sync. Sinh mới ngẫu nhiên ≥32 ký tự:
#   openssl rand -hex 24
# Token này được build vào bundle FE (VITE_API_TOKEN), nên thay đổi sẽ cần rebuild image FE.
MERIDIAN_API_TOKEN=CHANGE_ME_RANDOM_TOKEN_AT_LEAST_32_CHARS
